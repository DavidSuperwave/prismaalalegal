{
  "meta": {
    "lastTouchedVersion": "2026.3.7",
    "lastTouchedAt": "2026-03-14T18:10:00.000Z"
  },
  "agents": {
    "defaults": {
      "model": { "primary": "openrouter/moonshotai/kimi-k2.5" },
      "compaction": { "mode": "safeguard" }
    },
    "list": [
      { "id": "operator", "default": true, "name": "Operator Assistant", "workspace": "~/.openclaw/workspace-operator" },
      { "id": "leads-inbox", "name": "Leads Inbox SDR", "workspace": "~/.openclaw/workspace-leads-inbox" },
      { "id": "qualified-leads", "name": "Case Qualifier", "workspace": "~/.openclaw/workspace-qualified-leads" }
    ]
  },
  "tools": {
    "agentToAgent": { "enabled": true, "allow": ["operator", "leads-inbox", "qualified-leads"] }
  },
  "bindings": [
    { "agentId": "operator", "match": { "channel": "telegram", "accountId": "operator" } },
    { "agentId": "leads-inbox", "match": { "channel": "telegram", "accountId": "leads" } },
    { "agentId": "qualified-leads", "match": { "channel": "telegram", "accountId": "qualified" } },
    { "agentId": "operator", "match": { "channel": "whatsapp", "accountId": "default" } }
  ],
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${WHATSAPP_OPERATOR_PHONE}"],
      "groupPolicy": "disabled",
      "sendReadReceipts": true,
      "accounts": {
        "default": {
          "dmPolicy": "allowlist",
          "allowFrom": ["${WHATSAPP_OPERATOR_PHONE}"],
          "sendReadReceipts": true
        }
      }
    },
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "streaming": "partial",
      "accounts": {
        "operator": { "dmPolicy": "allowlist", "botToken": "${TELEGRAM_BOT_TOKEN_OPERATOR}", "allowFrom": ["${OPERATOR_TELEGRAM_USER_ID}"], "groupPolicy": "open", "streaming": "partial" },
        "leads": { "dmPolicy": "allowlist", "botToken": "${TELEGRAM_BOT_TOKEN_LEADS}", "allowFrom": ["${OPERATOR_TELEGRAM_USER_ID}"], "groupPolicy": "open", "streaming": "partial" },
        "qualified": { "dmPolicy": "allowlist", "botToken": "${TELEGRAM_BOT_TOKEN_QUALIFIED}", "allowFrom": ["${OPERATOR_TELEGRAM_USER_ID}"], "groupPolicy": "open", "streaming": "partial" }
      },
      "groups": { "-5190106102": {}, "-5107802002": {}, "-5052838020": {} }
    }
  },
  "gateway": {
    "bind": "lan",
    "controlUi": { "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"] },
    "auth": { "mode": "token", "token": "967e1b3fa5d5fcbc0eb163d589b6169aa7fadd560fbf1388" },
    "http": { "endpoints": { "chatCompletions": { "enabled": true }, "responses": { "enabled": true } } }
  }
}
