# ============================================
# OPENCLAW AGENT (Kimi K2.5 via OpenRouter)
# ============================================
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.7
OPENROUTER_API_KEY=sk-or-xxx

# ============================================
# TELEGRAM (Two Groups)
# ============================================
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_REPLIES_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_LEADS_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_DM_POLICY=pairing

# ============================================
# MANYCHAT
# ============================================
MANYCHAT_API_KEY=xxx
MANYCHAT_WEBHOOK_SECRET=xxx

# ============================================
# SUPERMEMORY
# ============================================
SUPERMEMORY_API_KEY=xxx

# ============================================
# AGENT IDENTITY
# ============================================
AGENT_SLUG=prismaalalegal
AGENT_NAME=Prisma Legal Agent

# ============================================
# WEB APP (Phase 2)
# ============================================
AUTH_EMAIL=admin@yourdomain.com
AUTH_PASSWORD=change-this-password
AUTH_NAME=Prisma Legal Admin
JWT_SECRET=random-32-char-string

NEXT_PUBLIC_CLIENT_NAME=Prisma Legal
NEXT_PUBLIC_CLIENT_SUBTITLE=Agent Platform
NEXT_PUBLIC_OPENCLAW_URL=http://openclaw:3100
OPENCLAW_WORKSPACE_SLUG=default
DATABASE_PATH=./data/template.db
WEB_APP_INTERNAL_URL=http://web:3000

# Backwards-compatible aliases used by older tooling
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password
NEXTAUTH_SECRET=random-32-char-string
NEXTAUTH_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Prisma Legal Agent

# ============================================
# INFRASTRUCTURE
# ============================================
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=your@email.com
OPENCLAW_GATEWAY_URL=http://openclaw:3100
