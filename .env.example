# ===== OPENCLAW =====
OPENCLAW_IMAGE=[REDACTED]
OPENROUTER_API_KEY=CHANGE_ME
OPENCLAW_HOME=~/.openclaw
OPENCLAW_AGENT_URL=http://openclaw:18789

# ===== TELEGRAM (3 bots) =====
TELEGRAM_BOT_TOKEN_OPERATOR=CHANGE_ME
TELEGRAM_BOT_TOKEN_LEADS=CHANGE_ME
TELEGRAM_BOT_TOKEN_QUALIFIED=CHANGE_ME
OPERATOR_TELEGRAM_USER_ID=CHANGE_ME
TELEGRAM_REPLIES_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_LEADS_CHAT_ID=-100xxxxxxxxxx

# Legacy fallback for older routes
TELEGRAM_BOT_TOKEN=CHANGE_ME_OPTIONAL

# ===== WHATSAPP (OpenClaw native channel via Baileys) =====
# Operator's WhatsApp number in E.164 format (e.g. +521812491200)
# Leave empty to disable WhatsApp notifications
WHATSAPP_OPERATOR_PHONE=

# ===== MANYCHAT =====
MANYCHAT_API_KEY=CHANGE_ME
MANYCHAT_WEBHOOK_SECRET=CHANGE_ME
MANYCHAT_AUTO_REPLY="Gracias por tu mensaje. Un asesor te atendera en breve."
MANYCHAT_CALLBACK_URL=https://yourdomain.com/api/webhooks/manychat/conversation

# WhatsApp outbound templates (set flow IDs after Meta approval)
MANYCHAT_CASE_ACCEPTED_FLOW_ID=
MANYCHAT_FOLLOW_UP_FLOW_ID=

# ===== SUPERMEMORY =====
SUPERMEMORY_API_KEY=CHANGE_ME

# ===== AGENT IDENTITY =====
AGENT_SLUG=[REDACTED]
AGENT_NAME=Prisma Legal Agent

# ===== WEB APP AUTH (required) =====
AUTH_EMAIL=CHANGE_ME@yourdomain.com
AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD
AUTH_NAME=Prisma Legal Admin
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

NEXT_PUBLIC_CLIENT_NAME=Prisma Legal
NEXT_PUBLIC_CLIENT_SUBTITLE=Agent Platform
NEXT_PUBLIC_OPENCLAW_URL=http://localhost:3100
OPENCLAW_WORKSPACE_SLUG=default
DATABASE_PATH=./data/template.db
WEB_APP_INTERNAL_URL=http://web:3000

# Backward-compatible aliases
ADMIN_EMAIL=CHANGE_ME@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
NEXTAUTH_SECRET=CHANGE_ME
NEXTAUTH_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Prisma Legal Agent

# ===== INFRASTRUCTURE =====
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=your@email.com
